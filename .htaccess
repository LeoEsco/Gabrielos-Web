# =============================================
# GABRIELOS PIZZA - OPTIMIZACIÓN DE RENDIMIENTO
# =============================================

# --- COMPRESIÓN GZIP ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# --- CACHÉ DEL NAVEGADOR ---
<IfModule mod_expires.c>
    ExpiresActive On

    # Imágenes: 30 días
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/jpg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"

    # CSS y JavaScript: 7 días
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"

    # Fuentes: 30 días
    ExpiresByType font/woff "access plus 30 days"
    ExpiresByType font/woff2 "access plus 30 days"
    ExpiresByType application/font-woff "access plus 30 days"
    ExpiresByType application/font-woff2 "access plus 30 days"

    # HTML: sin caché (siempre fresco)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# --- HEADERS DE CACHÉ ADICIONALES ---
<IfModule mod_headers.c>
    # Imágenes
    <FilesMatch "\.(jpg|jpeg|png|webp|gif|ico|svg)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # CSS y JS
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>

    # HTML y PHP
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # Seguridad básica
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# --- PREVENIR LISTADO DE DIRECTORIOS ---
Options -Indexes
